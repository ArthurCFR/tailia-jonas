# Clé API Google AI Studio (Gemini). NE JAMAIS committer la vraie clé.
GEMINI_API_KEY=

# Modèle de génération d'image. Défaut économe : gemini-2.5-flash-image (Nano Banana).
# Alternative plus qualitative et plus chère : gemini-3-pro-image-preview (Nano Banana Pro).
GEMINI_MODEL=gemini-2.5-flash-image

# Port d'écoute du serveur
PORT=3000

# (Prod Coolify) dossier de stockage persistant — non utilisé en V0 (stateless)
# STORAGE_DIR=/app/.storage
