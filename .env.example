# Clé API Google AI Studio (Gemini). NE JAMAIS committer la vraie clé.
GEMINI_API_KEY=

# --- Gemini (provider 1) ---
# Défaut qualité (fidélité visage/carrure) : gemini-3-pro-image (Nano Banana Pro).
# Alternative économe : gemini-3.1-flash-image.
GEMINI_MODEL=gemini-3-pro-image

# --- OpenAI (provider 2, A/B) ---
OPENAI_API_KEY=
# gpt-image-2 (haute fidélité auto), gpt-image-1.5, gpt-image-1
OPENAI_MODEL=gpt-image-2
# low ≈ 26s, medium ≈ 65s, high ≈ 130s (latence par image)
OPENAI_QUALITY=low

# Port d'écoute du serveur
PORT=3000
