# Clé API Google AI Studio (Gemini). NE JAMAIS committer la vraie clé.
GEMINI_API_KEY=

# Modèle de génération d'image.
# Défaut qualité (fidélité visage/carrure) : gemini-3-pro-image (Nano Banana Pro, plus cher).
# Alternative économe : gemini-3.1-flash-image (plus rapide/moins cher, fidélité un peu moindre).
GEMINI_MODEL=gemini-3-pro-image

# Port d'écoute du serveur
PORT=3000

# (Prod Coolify) dossier de stockage persistant — non utilisé en V0 (stateless)
# STORAGE_DIR=/app/.storage
